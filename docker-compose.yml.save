services:
  log-shield:
    build:
      context: ./
      dockerfile: Dockerfile
    image: febasec/log-shield:latest
    container_name: log-shield
    env_file:
      - ./src/colors.env
      - ./tg_creds.env
    environment:
      # Log files path. NOT FOR CONFIGURATION
      - ACCESS_LOG=/logs/nginx/access.log
      - AUTH_LOG=/logs/auth.log

      # Configure own whitelist. Recommended addresses: 127.0.0.1(loopback) and your own address (check with "ip a" command)
      - WHITELIST=127.0.0.1,192.168.0.1

      - MAX_ATTEMPTS=2
      # true - clear blacklist.txt file everytime. false - add info to existing data.
      - CLEAR_BLACKLIST=true
      - LOG_FILE=/app/data/log_shield.log
      - BLACKLIST_FILE=/app/data/blacklist.txt
    volumes:
      # Configure own path to log files. Only first part (before ":"). 
      - ./mock_nginx.log:/logs/nginx/access.log:ro
      - ./mock_auth.log:/logs/auth.log:ro
      # Saving results in "data/" directory
      - ./data:/app/data
